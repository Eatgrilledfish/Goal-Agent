{
  "_comment": "JSON Schema for /result/issues.json, conforming to section 7.4 of FIX-rfc-migration.md. final_detection_gate.py validates output against this.",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RfcImplementationDiffResult",
  "type": "object",
  "required": ["generated_at", "tool", "code_root", "benchmark", "summary", "issues"],
  "properties": {
    "generated_at": {"type": "string"},
    "tool": {"type": "string", "const": "goal-agent-rfc-diff"},
    "code_root": {"type": "string"},
    "benchmark": {"type": "string"},
    "summary": {
      "type": "object",
      "required": ["total", "confirmed", "probable", "high_confidence"],
      "properties": {
        "total": {"type": "integer", "minimum": 0},
        "confirmed": {"type": "integer", "minimum": 0},
        "probable": {"type": "integer", "minimum": 0},
        "high_confidence": {"type": "integer", "minimum": 0}
      }
    },
    "issues": {
      "type": "array",
      "items": {"$ref": "#/definitions/Issue"}
    }
  },
  "definitions": {
    "Issue": {
      "type": "object",
      "required": [
        "issue_id",
        "title",
        "status",
        "confidence",
        "normative_level",
        "design_evidence",
        "code_evidence",
        "inconsistency",
        "impact",
        "false_positive_controls",
        "related_files",
        "report_path",
        "agent_review"
      ],
      "properties": {
        "issue_id": {"type": "string"},
        "title": {"type": "string"},
        "status": {"type": "string", "enum": ["confirmed"]},
        "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0},
        "normative_level": {"type": "string"},
        "design_evidence": {
          "type": "object",
          "required": ["rfc", "section", "doc_path", "quote"],
          "properties": {
            "rfc": {"type": "string"},
            "section": {"type": "string"},
            "doc_path": {"type": "string"},
            "quote": {"type": "string"}
          }
        },
        "code_evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["file", "line_start", "line_end", "symbol", "snippet"],
            "properties": {
              "file": {"type": "string"},
              "line_start": {"type": "integer"},
              "line_end": {"type": "integer"},
              "symbol": {"type": "string"},
              "snippet": {"type": "string"}
            }
          }
        },
        "inconsistency": {"type": "string"},
        "impact": {"type": "string"},
        "false_positive_controls": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "related_files": {"type": "array", "items": {"type": "string"}},
        "report_path": {"type": "string"},
        "agent_review": {
          "type": "object",
          "required": ["source", "agent_notes", "generalization_rationale", "tool_trace"],
          "properties": {
            "source": {"type": "string", "const": "opencode"},
            "candidate_id": {"type": "string"},
            "agent_notes": {"type": "string"},
            "generalization_rationale": {"type": "string"},
            "tool_trace": {"type": "array", "minItems": 1}
          }
        }
      }
    }
  }
}
