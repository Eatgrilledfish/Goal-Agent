{
  "_comment": "Hardcoded RFC *selection policy* for the scope-planner phase. This intentionally contains NO RFC numbers -- the rule is the policy, not a fixed RFC list. The planner scores every RFC discovered in benchmark.md against these preferences and selects dynamically, so the system adapts to any RFC set the benchmark throws at it. See FIX-rfc-scope-planner.md.",

  "prefer_current_core_protocol": true,
  "prefer_must_level_requirements": true,
  "prefer_code_checkable_behavior": true,
  "exclude_operational_guidance": true,
  "exclude_obsoleted_if_successor_present": true,
  "max_primary_rfcs": 8,

  "primary_score_threshold": 0.75,
  "min_primary_rfcs": 4,

  "scoring_weights": {
    "normative_strength": 0.25,
    "implementation_boundary": 0.25,
    "code_anchor": 0.20,
    "contradiction_testability": 0.15,
    "security_or_protocol_core": 0.10,
    "current_rfc_status": 0.05
  },

